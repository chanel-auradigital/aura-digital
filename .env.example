# API Keys — copiar como .env y llenar con valores reales
# NO commitear .env — solo .env.example

# Fireflies (transcripciones de reuniones)
FIREFLIES_API_KEY=tu-api-key-aqui

# Meta / Instagram Graph API (generales)
# Obtener siguiendo el flujo OAuth documentado en scripts/README.md
META_APP_ID=tu-app-id
META_APP_SECRET=tu-app-secret
META_ACCESS_TOKEN=tu-long-lived-token
INSTAGRAM_ACCOUNT_ID=tu-ig-business-account-id

# Meta / Instagram — tokens por cliente
# Cada cliente tiene su propio token y account ID
META_ACCESS_TOKEN_MARIA_JOSE=tu-token
INSTAGRAM_ACCOUNT_ID_MARIA_JOSE=tu-account-id
META_ACCESS_TOKEN_GUADALUPE_ACERO=tu-token
INSTAGRAM_ACCOUNT_ID_GUADALUPE_ACERO=tu-account-id
META_ACCESS_TOKEN_CHANEL_DE_LA_ROSA=tu-token
INSTAGRAM_ACCOUNT_ID_CHANEL_DE_LA_ROSA=tu-account-id

# Canva API
CANVA_CLIENT_ID=tu-client-id
CANVA_CLIENT_SECRET=tu-client-secret
CANVA_ACCESS_TOKEN=tu-access-token
CANVA_REFRESH_TOKEN=tu-refresh-token

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Vercel (deploy y hosting)
# Cuenta: chenlauradigital@gmail.com
VERCEL_TOKEN=tu-vercel-token
